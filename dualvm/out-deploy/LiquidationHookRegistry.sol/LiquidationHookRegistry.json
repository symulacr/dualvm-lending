name\":\"reason\",\"type\":\"bytes\"}],\"name\":\"HookFailed\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"hookType\",\"type\":\"bytes32\"},{\"indexed\":true,\"internalType\":\"address\",\"name\":\"handler\",\"type\":\"address\"}],\"name\":\"HookRegistered\",\"type\":\"event\"},{\"inputs\":[],\"name\":\"DEFAULT_HOOK_TYPE\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"authority\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"hookType\",\"type\":\"bytes32\"}],\"name\":\"deregisterHook\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"hookType\",\"type\":\"bytes32\"},{\"internalType\":\"bytes\",\"name\":\"data\",\"type\":\"bytes\"}],\"name\":\"executeHooks\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"hookType\",\"type\":\"bytes32\"}],\"name\":\"getHook\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"isConsumingScheduledOp\",\"outputs\":[{\"internalType\":\"bytes4\",\"name\":\"\",\"type\":\"bytes4\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"borrower\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"debtRepaid\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"collateralSeized\",\"type\":\"uint256\"},{\"internalType\":\"bytes32\",\"name\":\"correlationId\",\"type\":\"bytes32\"}],\"name\":\"notifyLiquidation\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"hookType\",\"type\":\"bytes32\"},{\"internalType\":\"address\",\"name\":\"handler\",\"type\":\"address\"}],\"name\":\"registerHook\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"newAuthority\",\"type\":\"address\"}],\"name\":\"setAuthority\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"Wire this contract as the liquidationNotifier on LendingEngine.  LendingEngine calls ILiquidationNotifier.notifyLiquidation(borrower, debtRepaid, collateralSeized), which hits this contract.  The registry then re-dispatches to each registered hook for the DEFAULT_HOOK_TYPE with the same 3-arg signature.\",\"events\":{\"AuthorityUpdated(address)\":{\"details\":\"Authority that manages this contract was updated.\"}},\"kind\":\"dev\",\"methods\":{\"authority()\":{\"details\":\"Returns the current authority.\"},\"deregisterHook(bytes32)\":{\"params\":{\"hookType\":\"Identifier for the hook category.\"}},\"executeHooks(bytes32,bytes)\":{\"details\":\"data must be ABI-encoded as (address borrower, uint256 debtRepaid, uint256 collateralSeized, bytes32 correlationId).         If no handler is registered, returns silently (no revert).         If the handler reverts, emits HookFailed and continues.\",\"params\":{\"data\":\"ABI-encoded (address, uint256, uint256, bytes32) liquidation parameters.\",\"hookType\":\"Identifier for the hook category.\"}},\"isConsumingScheduledOp()\":{\"details\":\"Returns true only in the context of a delayed restricted call, at the moment that the scheduled operation is being consumed. Prevents denial of service for delayed restricted calls in the case that the contract performs attacker controlled calls.\"},\"notifyLiquidation(address,uint256,uint256,bytes32)\":{\"details\":\"Dispatches to the DEFAULT_HOOK_TYPE handler via executeHooks.\",\"params\":{\"borrower\":\"The liquidated borrower's address.\",\"collateralSeized\":\"The amount of collateral transferred to the liquidator.\",\"correlationId\":\"A unique identifier linking this liquidation to its event trace.\",\"debtRepaid\":\"The amount of debt repaid by the liquidator.\"}},\"registerHook(bytes32,address)\":{\"params\":{\"handler\":\"Contract implementing ILiquidationNotifier.\",\"hookType\":\"Identifier for the hook category.\"}},\"setAuthority(address)\":{\"details\":\"Transfers control to a new authority. The caller must be the current authority.\"}},\"title\":\"LiquidationHookRegistry\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"DEFAULT_HOOK_TYPE()\":{\"notice\":\"Default hook type used by LendingEngine post-liquidation.\"},\"deregisterHook(bytes32)\":{\"notice\":\"Remove the hook handler for a given type.\"},\"executeHooks(bytes32,bytes)\":{\"notice\":\"Execute the registered hook for hookType with the given ABI-encoded data.\"},\"getHook(bytes32)\":{\"notice\":\"Returns the handler registered for hookType (address(0) if none).\"},\"notifyLiquidation(address,uint256,uint256,bytes32)\":{\"notice\":\"Called after a successful liquidation.\"},\"registerHook(bytes32,address)\":{\"notice\":\"Register a hook handler for a given type (replaces any existing handler).\"}},\"notice\":\"Governance-managed registry mapping hook types to post-liquidation handlers. Each hook type (a bytes32 key) maps to one handler address that implements ILiquidationNotifier.  Governance can register or deregister handlers at any time. executeHooks dispatches to the registered handler inside a try/catch so a reverting hook never propagates to the caller (e.g. LendingEngine liquidation).\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/LiquidationHookRegistry.sol\":\"LiquidationHookRegistry\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/=node_modules/@openzeppelin/\",