{
  "name": "dualvm-lending",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "build:pvm": "node scripts/build-pvm.mjs",
    "build:app": "vite build",
    "build": "npm run compile && npm run build:pvm && npm run build:app",
    "dev": "vite",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network polkadotHubTestnet",
    "verify:testnet": "hardhat run scripts/verifyAll.ts --network polkadotHubTestnet",
    "repay-smoke:testnet": "hardhat run scripts/liveRepaySmoke.ts --network polkadotHubTestnet",
    "risk-smoke:testnet": "hardhat run scripts/liveRiskAdminSmoke.ts --network polkadotHubTestnet",
    "oracle-smoke:testnet": "hardhat run scripts/liveOracleSmoke.ts --network polkadotHubTestnet",
    "minter-smoke:testnet": "hardhat run scripts/liveMinterSmoke.ts --network polkadotHubTestnet",
    "oracle-upgrade:testnet": "hardhat run scripts/upgradeOracle.ts --network polkadotHubTestnet",
    "watch:testnet": "node scripts/liquidation-watch.mjs",
    "index-events:testnet": "node scripts/snapshot-recent-events.mjs",
    "liquidate:testnet": "hardhat run scripts/executeLiquidation.ts --network polkadotHubTestnet",
    "governance:apply": "hardhat run scripts/applyRoleSeparation.ts --network polkadotHubTestnet",
    "wallet:generate": "node scripts/generate-wallet.mjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "viem": "^2.37.13"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^5.5.0",
    "@parity/resolc": "^1.0.0",
    "@polkadot/api": "^16.5.4",
    "@polkadot/util-crypto": "^14.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
