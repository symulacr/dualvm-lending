{
  "idleTimeoutMs": 900000,
  "servers": {
    "typescript-language-server": {
      "rootMarkers": ["tsconfig.json", "jsconfig.json"]
    },
    "vscode-json-language-server": {
      "rootMarkers": [".lsp.json"]
    },
    "vscode-css-language-server": {
      "rootMarkers": [".lsp.json"]
    },
    "vscode-html-language-server": {
      "command": "vscode-html-language-server",
      "args": ["--stdio"],
      "fileTypes": [".html", ".htm"],
      "rootMarkers": [".lsp.json"],
      "initOptions": {
        "provideFormatter": true
      }
    },
    "pyright": {
      "rootMarkers": [".lsp.json"]
    },
    "ruff": {
      "rootMarkers": [".lsp.json"]
    },
    "rust-analyzer": {
      "rootMarkers": [".lsp.json"]
    },
    "taplo": {
      "command": "taplo",
      "args": ["lsp", "stdio"],
      "fileTypes": [".toml"],
      "rootMarkers": [".lsp.json"]
    },
    "nomicfoundation-solidity-language-server": {
      "command": "nomicfoundation-solidity-language-server",
      "args": ["--stdio"],
      "fileTypes": [".sol"],
      "rootMarkers": ["hardhat.config.ts", "hardhat.config.js", "foundry.toml", "remappings.txt"]
    }
  }
}
